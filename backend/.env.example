# ============================================
# GitCity Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-app.netlify.app

# ─── GitHub OAuth ────────────────────────────────────────────
# Create a GitHub OAuth App at: https://github.com/settings/developers
# Set the callback URL to: https://your-backend.onrender.com/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://your-backend.onrender.com/auth/github/callback

# ─── JWT Secret ──────────────────────────────────────────────
# Generate a strong random string (64+ chars)
# Example: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ─── PostgreSQL (Prisma) ─────────────────────────────────────
# Render provides this automatically when you add a PostgreSQL database
DATABASE_URL=postgresql://user:password@host:5432/gitcity?schema=public

# ─── Redis ───────────────────────────────────────────────────
# Render provides this when you add a Redis instance
# App works without it (in-memory fallback) but Redis is recommended for production
REDIS_URL=redis://host:6379

# ─── GitHub Webhooks (Optional) ──────────────────────────────
# Set a secret string and configure the same in your GitHub webhook settings
# Without this, webhooks run in dev mode (no signature verification)
GITHUB_WEBHOOK_SECRET=
